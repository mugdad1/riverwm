#!/bin/sh
# Clipboard manager using cliphist and wofi

CONFIG="$HOME/.config/river/wofi/config"
STYLE="$HOME/.config/river/wofi/style.css"

STORE_MODE="${1:-}"
if [ "$STORE_MODE" = "--store" ]; then
    cliphist store
    exit 0
fi

SELECTED=$(cliphist list | wofi --conf "$CONFIG" --style "$STYLE" --show=dmenu --prompt "Clipboard" --location=top --normal-window)

if [ -n "$SELECTED" ]; then
    ID=$(echo "$SELECTED" | cut -d: -f1)
    cliphist decode "$ID" | wl-copy
fi
